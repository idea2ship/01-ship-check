# Groq — LLM provider (free tier available at https://console.groq.com)
# Sign in → Create API Key → paste here.
GROQ_API_KEY=

# Optional: override the model. Default in code is "llama-3.3-70b-versatile".
# Other free options on Groq:
#   - llama-3.1-8b-instant  (faster, slightly lower quality)
#   - mixtral-8x7b-32768    (different style)
#   - gemma2-9b-it
# GROQ_MODEL=llama-3.3-70b-versatile

# Supabase — Project Settings > API
# URL form: https://<your-project-ref>.supabase.co
SUPABASE_URL=

# WARNING: service_role key bypasses RLS. Server-only. Never expose to the client.
# Found under "Project Settings > API > service_role" (or new label: "secret").
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Workers AI — concept image generation
# Free tier: 10,000 neurons/day (≈ 120 flux-schnell images/day, always free).
# Sign up at https://dash.cloudflare.com → Workers AI.
# CF_ACCOUNT_ID: visible in dashboard URL (https://dash.cloudflare.com/<ACCOUNT_ID>/...)
# CF_API_TOKEN: My Profile → API Tokens → Create Token → "Workers AI" template
#               (or custom token with permission: Account → Workers AI → Read)
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Optional: separate token for usage analytics (./scripts/cf-usage.sh).
# Permission needed: Account → Account Analytics → Read.
# Not used by the app itself, only by the local usage-check script.
CF_ANALYTICS_TOKEN=
